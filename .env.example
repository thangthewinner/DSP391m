# Model paths
MODEL_CACHE_DIR=./models
HF_HOME=./models/.cache

# API configuration
API_HOST=0.0.0.0
API_PORT=8000
WS_MAX_SIZE=10485760

# Processing configuration
AUDIO_SAMPLE_RATE=16000
AUDIO_CHUNK_SIZE=2.0
VAD_THRESHOLD=0.5
BUFFER_SIZE=10.0

# Thresholds (for Phase 2+)
SIMILARITY_THRESHOLD_LOW=0.60
SIMILARITY_THRESHOLD_HIGH=0.75
SPEAKER_VERIFICATION_THRESHOLD=0.75
CHEATING_THRESHOLD=10.0
DECAY_FACTOR=0.9

# Storage
STORAGE_ROOT=./storage
DEBUG_SAVE_AUDIO=false

# Device configuration
# Use 'cpu' for CPU-only systems, 'cuda' for GPU systems
TORCH_DEVICE=cpu

# For GPU systems, uncomment and set:
# CUDA_VISIBLE_DEVICES=0
# TORCH_DEVICE=cuda

# SLM Configuration (Phase 3 — Reasoning Layer)
# Download model first: uv run python scripts/download_models.py --slm
SLM_ENABLED=true
# SLM_MODEL_PATH=./models/slm/qwen2.5-3b-instruct-q4_k_m.gguf
# SLM_N_GPU_LAYERS=0   # 0=CPU only. -1=all layers on GPU (needs VRAM)
# SLM_MAX_TOKENS=4
# SLM_CONTEXT_LENGTH=512
